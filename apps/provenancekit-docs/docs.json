{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ProvenanceKit",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "heading": {
      "family": "Fragment Mono"
    },
    "body": {
      "family": "Inter"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Introduction",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "introduction/architecture",
              "introduction/eaa-model"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "quickstart",
              "guides/recording-provenance"
            ]
          },
          {
            "group": "Extensions",
            "pages": [
              "guides/extensions",
              "guides/ai-extension"
            ]
          },
          {
            "group": "Infrastructure",
            "pages": [
              "guides/on-chain",
              "guides/payments",
              "guides/privacy",
              "guides/self-hosting"
            ]
          },
          {
            "group": "Domain Packages",
            "pages": [
              "guides/git-provenance",
              "guides/media-c2pa"
            ]
          }
        ]
      },
      {
        "tab": "UI Components",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "ui-reference/overview"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "ui-reference/provenance-badge",
              "ui-reference/provenance-graph",
              "ui-reference/provenance-tracker",
              "ui-reference/provenance-bundle-view",
              "ui-reference/provenance-search",
              "ui-reference/primitives",
              "ui-reference/extension-views"
            ]
          }
        ]
      },
      {
        "tab": "SDK Reference",
        "groups": [
          {
            "group": "SDK",
            "pages": [
              "sdk-reference/client",
              "sdk-reference/chain-adapters"
            ]
          }
        ]
      },
      {
        "tab": "Patterns",
        "groups": [
          {
            "group": "Legal & Compliance",
            "pages": [
              "patterns/model-training-provenance",
              "patterns/human-creative-input",
              "patterns/authorization-consent"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Arttribute/provenancekit",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/search?q=%40provenancekit",
          "icon": "npm"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Arttribute/provenancekit"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.provenancekit.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/provenancekit",
      "github": "https://github.com/Arttribute/provenancekit"
    }
  }
}
