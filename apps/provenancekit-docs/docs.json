{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ProvenanceKit",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Introduction",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "introduction/architecture",
              "introduction/eaa-model"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "quickstart",
              "guides/recording-provenance"
            ]
          },
          {
            "group": "Extensions",
            "pages": [
              "guides/extensions",
              "guides/ai-extension"
            ]
          },
          {
            "group": "Protocol",
            "pages": [
              "protocol/contracts"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/provenancekit/provenancekit",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/search?q=%40provenancekit",
          "icon": "npm"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/provenancekit/provenancekit"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.provenancekit.org"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/provenancekit",
      "github": "https://github.com/provenancekit/provenancekit"
    }
  }
}
