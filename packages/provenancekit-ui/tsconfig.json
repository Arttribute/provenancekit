{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "typeRoots": ["../../node_modules/@types", "../../node_modules/.pnpm/node_modules/@types"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
