# ── Privy Auth (Required) ─────────────────────────────────────────────────────
# Get from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=clxxxxxxxxxxxxxxxxxxxxxxx
PRIVY_APP_SECRET=

# ── MongoDB (Required) ────────────────────────────────────────────────────────
# The chat app's own database — separate from the ProvenanceKit API database.
MONGODB_URI=mongodb://localhost:27017/provenancekit-chat

# ── AI Providers ──────────────────────────────────────────────────────────────
# OpenAI (Required — primary provider, powers GPT-4o by default)
OPENAI_API_KEY=sk-proj-...

# Anthropic (Optional — enables Claude models in the model selector)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Optional — enables Gemini models in the model selector)
GOOGLE_AI_API_KEY=AIza...

# Custom OpenAI-compatible endpoint (Optional)
# CUSTOM_AI_BASE_URL=https://your-endpoint.com/v1
# CUSTOM_AI_API_KEY=...

# ── ProvenanceKit Integration ─────────────────────────────────────────────────
# App-level PK config — one key shared by all users of this chat app.
#
# How to get your API key:
#   1. Start the ProvenanceKit API:  cd apps/provenancekit-api && pnpm dev
#   2. Start the PK dashboard:       cd apps/provenancekit-app && pnpm dev
#   3. Sign in → Create organization → Create project → Generate API key
#   4. Copy the pk_live_... key and paste it below
#
PK_API_URL=http://localhost:3001
PK_API_KEY=pk_live_...
PK_PROJECT_ID=                    # Optional: scope all records to a specific project
PK_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs  # Persistent URL prefix for IPFS-pinned images

# ── Pinata / IPFS (Optional — for file attachments) ───────────────────────────
# Required for persistent file uploads. Without this, attachments fall back to
# base64 data URLs (fine for local dev, breaks on MongoDB's 16 MB doc limit in prod).
# Get from https://app.pinata.cloud/keys
PINATA_JWT=

# ── App Configuration ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002

# URL shown in the Settings page to help users get their own PK API keys
NEXT_PUBLIC_PK_DASHBOARD_URL=http://localhost:3000