# ─────────────────────────────────────────────────────────────
# Canvas — Environment Variables
#
# Setup guide:
#   1. Create a project at app.provenancekit.org
#   2. Generate an API key → paste as PROVENANCEKIT_API_KEY
#   3. Configure Privy at privy.io → paste APP_ID + SECRET
#   4. Connect your MongoDB Atlas cluster
#   5. Get a Pinata JWT for IPFS media uploads
# ─────────────────────────────────────────────────────────────

# Privy Auth
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/canvas?retryWrites=true&w=majority

# ── ProvenanceKit ─────────────────────────────────────────────
# Canvas is a platform integration: ONE key for the whole platform.
# Users are entities within your Canvas project — they don't need
# their own keys. Get yours at: app.provenancekit.org
PROVENANCEKIT_API_URL=https://api.provenancekit.org
PROVENANCEKIT_API_KEY=pk_live_your_key_here

# ── Blockchain (Base Sepolia for dev, Base Mainnet for prod) ──
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_CHAIN_ID=84532

# ── IPFS / Pinata (for media uploads) ─────────────────────────
PINATA_JWT=your-pinata-jwt
NEXT_PUBLIC_IPFS_GATEWAY=coral-abstract-dolphin-257.mypinata.cloud
