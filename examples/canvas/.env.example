# Privy Auth
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/canvas?retryWrites=true&w=majority

# Blockchain (Base Sepolia for dev, Base Mainnet for prod)
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_CHAIN_ID=84532

# ProvenanceKit (each user brings their own from app.provenancekit.org)
# These are server-side fallbacks — users configure per-account in Settings
PROVENANCEKIT_API_URL=https://api.provenancekit.org
# PROVENANCEKIT_API_KEY=pk_live_...  # optional platform-level key

# IPFS Gateway (for displaying content — uploads go through the ProvenanceKit API)
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
